PORT=3000
NODE_ENV=development

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# MySQL 数据库配置
# 请先在 MySQL 中创建数据库: CREATE DATABASE mody_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mody_db
DB_USER=root
DB_PASSWORD=你的MySQL密码

CORS_ORIGIN=http://localhost:5173

# 阿里云短信（验证码发送）。不配置时验证码仅落库不真实发送，开发环境响应中会返回 code
# 申请步骤见 README 或文档
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
